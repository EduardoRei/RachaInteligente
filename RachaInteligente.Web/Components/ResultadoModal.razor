@if (Visivel)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.6); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 2050;">
        <div class="modal-dialog modal-lg modal-dialog-centered shadow-lg">
            <div class="modal-content border-0 rounded-4">
                <div class="modal-header bg-success text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-check-circle me-2"></i>Cálculo Concluído com Sucesso!</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="OnFechar"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <h6 class="fw-bold mb-3">Relatório de Acertos:</h6>
                    <div class="bg-white border rounded p-3 shadow-inner" style="max-height: 400px; overflow-y: auto;">
                        <pre class="mb-0 font-monospace small" style="white-space: pre-wrap;">@Texto</pre>
                    </div>
                </div>
                <div class="modal-footer bg-white border-0 py-3">
                    <button class="btn btn-outline-secondary px-4" @onclick="OnFechar">Fechar</button>
                    <button class="btn btn-success px-4 fw-bold" @onclick="OnBaixar">
                        <i class="bi bi-download me-2"></i> Baixar Relatório (.txt)
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visivel { get; set; }
    [Parameter] public string Texto { get; set; } = "";
    [Parameter] public EventCallback OnFechar { get; set; }
    [Parameter] public EventCallback OnBaixar { get; set; }
}
